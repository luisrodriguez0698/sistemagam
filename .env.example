# Copia este archivo a ".env" y completa con tus valores reales.
# ".env" NUNCA se sube al repositorio (ver .gitignore).

# Cadena de conexión a PostgreSQL usada por Prisma.
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestion_agencias?schema=public"

# --- Auth (ajustar según el proveedor que integres en lib/tenant.ts) ---
# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-uno-con: openssl rand -base64 32"

# --- Cloudflare R2 (imágenes de referencia de los entregables) ---
# Cuenta > R2 Object Storage > Manage API tokens > Create API token.
# El bucket debe tener acceso público (dominio r2.dev) habilitado para que
# las miniaturas se puedan mostrar directo y embeberse en el PDF de resumen.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="" # ej. https://pub-xxxxxxxx.r2.dev
